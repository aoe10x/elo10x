{
  "name": "elo10x",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "bin": {
    "elo10x": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run test:node",
    "test:node": "node --test test/**/*.test.ts",
    "crawl:relic": "node src/cli.ts crawl --engine relic",
    "crawl:insights": "node src/cli.ts crawl --engine insights",
    "scrape:player": "node src/cli.ts scrape",
    "elo": "node src/cli.ts elo",
    "dev": "statikk dist --port 3000",
    "deploy": "gh-pages -d dist -m \"chore: deploy static leaderboard [skip ci]\"",
    "preflight": "pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "gh-pages": "^6.3.0",
    "statikk": "^3.0.0",
    "typescript": "^5.7.3"
  }
}
