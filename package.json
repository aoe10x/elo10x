{
  "name": "elo10x",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "bin": {
    "elo10x": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run test:node",
    "test:node": "node --test test/**/*.test.ts",
    "crawl:relic": "node src/cli.ts crawl --engine relic",
    "crawl:insights": "node src/cli.ts crawl --engine insights",
    "scrape:player": "node src/cli.ts scrape",
    "elo": "node src/cli.ts elo",
    "dev": "statikk dist --port 3000",
    "deploy": "gh-pages --dist dist --no-history --message \"chore: deploy static leaderboard [skip ci]\"",
    "lint": "oxlint --config .oxlintrc.json",
    "preflight": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "devtools-protocol": "^0.0.1660672",
    "gh-pages": "^6.3.0",
    "oxlint": "^1.74.0",
    "statikk": "^3.0.0",
    "typescript": "^5.7.3"
  }
}
