{
  "name": "elo10x",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run test:node",
    "test:node": "node --experimental-strip-types --test test/**/*.test.ts",
    "crawl": "node --experimental-strip-types src/cli.ts --crawl",
    "elo": "node --experimental-strip-types src/compile.ts",
    "dev": "statikk docs --port 3000",
    "preflight": "pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "statikk": "^3.0.0",
    "typescript": "^5.7.3"
  }
}
