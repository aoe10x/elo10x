{
  "name": "elo10x",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run test:node",
    "test:node": "node --test test/**/*.test.ts",
    "crawl:relic": "node src/cli.ts relic",
    "crawl:insights": "node src/cli.ts insights crawl",
    "scrape:player": "node src/cli.ts insights",
    "elo": "node src/cli.ts elo",
    "dev": "statikk docs --port 3000",
    "preflight": "pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "statikk": "^3.0.0",
    "typescript": "^5.7.3"
  }
}
